# =============================================================
# CardioCare AI — Environment Variables TEMPLATE
# Copy this file, rename to .env, and fill in your values
# =============================================================

# ── ADMIN CREDENTIALS ────────────────────────────────────────
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_strong_password_here

# ── DATABASE ─────────────────────────────────────────────────
DB_PATH=cardiocare.db

# ── FLASK SERVER ─────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False
FLASK_SECRET_KEY=generate_a_random_string_here

# ── RASPBERRY PI ─────────────────────────────────────────────
DEVICE_NAME="CardioNet-HX"
DEVICE_VERSION=1.0
PI_LOCAL_IP=192.168.1.100

# ── SESSION ──────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=3

# ── PATHS ────────────────────────────────────────────────────
MODELS_DIR=models
SCALERS_DIR=scalers
LOGS_DIR=logs
