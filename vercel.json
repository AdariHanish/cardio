{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": null,
      "entrypoint": "."
    },
    "backend": {
      "routePrefix": "/api",
      "runtime": "@vercel/python",
      "entrypoint": "api/index.py"
    }
  },
  "version": 2,
  "env": {
    "PYTHONPATH": "backend"
  }
}
